# Nginx configuration snippet for Webhook Blog
# Add this to your server block in /etc/nginx/sites-available/your-domain

server {
    listen 80;
    server_name yourdomain.com;
    root /var/www/blogee;
    index index.html;

    # RULE 1: Block access to all hidden files (dotfiles)
    # This protects .env, .git, .htaccess, etc.
    location ~ /\.(?!well-known) {
        deny all;
        access_log off;
        log_not_found off;
    }

    # RULE 2: Block sensitive system and metadata files
    # Protects README, LICENSE, internal scripts, and spec documents
    location ~* \.(md|sh|log|docx|example|LICENSE.*)$ {
        deny all;
        access_log off;
        log_not_found off;
    }


    # RULE 3: Disable PHP execution in the content/ directory
    # Prevents a compromised or malicious commit from executing PHP
    location ^~ /content/ {
        location ~ \.(php|phtml|php8\.3)$ {
            deny all;
        }
        try_files $uri $uri/ =404;
    }

    # RULE 4: Rate limit webhook endpoint
    location = /webhook.php {
        # Note: You must define the 'webhook' zone in the http block
        limit_req zone=webhook burst=5 nodelay;
        include /etc/nginx/fastcgi_params;
        fastcgi_pass unix:/var/run/php/php8.3-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
    }

    # RULE 5: Standard PHP-FPM processing for other .php files
    location ~ \.php$ {
        include /etc/nginx/fastcgi_params;
        fastcgi_pass unix:/var/run/php/php8.3-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
    }

    location / {
        try_files $uri $uri/ =404;
    }
}

# CRITICAL: Rate limiting zone definition
# You MUST add this line to your MAIN /etc/nginx/nginx.conf file, INSIDE the 'http { ... }' block.
# The ':10m' part specifies the memory size; omitting it will cause a 'zero size shared memory' error.
# limit_req_zone $binary_remote_addr zone=webhook:10m rate=10r/m;
