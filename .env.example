# GitHub Webhook Secret Key
# Generate one using: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your_super_secret_token_here

# Sync Method: git (default) or archive (for servers without git)
SYNC_METHOD=archive

# Repo Archive URL (Example for GitHub: https://github.com/USER/REPO/tarball/main)
REPO_ARCHIVE_URL=https://github.com/your-username/your-content-repo/tarball/main
